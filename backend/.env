# ==============================================
# Meta App — Configuração do Backend
# Edite este arquivo com suas credenciais reais
# ==============================================

# Ambiente
DEBUG=true

# Segurança JWT — TROQUE EM PRODUÇÃO!
SECRET_KEY=mude-esta-chave-em-producao-use-openssl-rand-hex-32

# Banco de Dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=metaapp

# CORS — URLs do frontend permitidas
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Tokens
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7
