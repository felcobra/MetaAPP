# ==============================================
# Meta App — Configuração do Backend
# Copie este arquivo como .env e preencha os valores
# ==============================================

# Ambiente
DEBUG=true

# Segurança JWT (gere uma chave forte em produção)
SECRET_KEY=mude-esta-chave-em-producao-use-openssl-rand-hex-32

# Banco de Dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=metaapp

# CORS — URLs permitidas (separadas por vírgula)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Tokens
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7
